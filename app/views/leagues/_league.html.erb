<div id="<%= dom_id league %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= league.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Scoring format:</strong>
    <%= league.scoring_format %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Player:</strong>
    <%= league.player_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Platform:</strong>
    <%= league.platform %>
  </div>
</div>
